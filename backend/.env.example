# Qdrant (required)
# Local: http://localhost:6333 (API key optional)
# Cloud: https://your-cluster.qdrant.io
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# LLM providers (required)
OPENAI_API_KEY=sk-your-openai-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
LLM_PROVIDER=claude

# Collection / embeddings
COLLECTION_NAME=automotive_connectors
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EXTRACTION_TEMPERATURE=0.0

# Qdrant ACORN (optional)
ACORN_ENABLED=true
ACORN_MAX_SELECTIVITY=0.4

# Neo4j graph features (optional — leave unset to disable)
# AuraDB: neo4j+s://xxxx.databases.neo4j.io
# Local:  bolt://localhost:7687
NEO4J_URI=
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
